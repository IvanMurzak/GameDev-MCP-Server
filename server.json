{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-07-09/server.schema.json",
  "name": "io.github.IvanMurzak/GameDev-MCP-Server",
  "description": "Make games with AI. Engine-agnostic MCP server shared by the Unity-MCP, Godot-MCP and Unreal-MCP editor plugins.",
  "status": "active",
  "repository": {
    "url": "https://github.com/IvanMurzak/GameDev-MCP-Server",
    "source": "github"
  },
  "version": "8.0.2",
  "packages": [
    {
      "registry_type": "oci",
      "registry_base_url": "https://docker.io",
      "identifier": "aigamedeveloper/mcp-server",
      "version": "8.0.2",
      "transport": {
        "type": "stdio"
      },
      "environment_variables": [
        {
          "name": "MCP_PLUGIN_PORT",
          "description": "Client -> Server <- Plugin connection port (default: 8080)",
          "format": "number",
          "is_required": false,
          "is_secret": false
        },
        {
          "name": "MCP_PLUGIN_CLIENT_TIMEOUT",
          "description": "Plugin -> Server connection timeout (ms) (default: 10000)",
          "format": "number",
          "is_required": false,
          "is_secret": false
        },
        {
          "name": "MCP_PLUGIN_CLIENT_TRANSPORT",
          "description": "Client -> Server transport type: stdio or streamableHttp (default: stdio)",
          "format": "string",
          "default": "stdio",
          "enum": [
            "streamableHttp",
            "stdio"
          ],
          "is_required": false,
          "is_secret": false
        }
      ]
    }
  ]
}
